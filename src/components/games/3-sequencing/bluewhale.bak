<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Mega Animal & Vehicle Builder!</title>
    <style>
        body {
            font-family: 'Comic Sans MS', sans-serif;
            background-color: #f0fdfa;
            display: flex;
            flex-direction: column;
            align-items: center;
            touch-action: none;
            height: 100vh;
            margin: 0;
            overflow: hidden;
            user-select: none;
        }

        #game-bar {
            width: 100%;
            padding: 12px;
            text-align: center;
            background: #cbd5e1;
            font-weight: bold;
            color: #334155;
            font-size: 1.1rem;
        }

        h1 { font-size: 1.6rem; margin: 15px 0 5px 0; color: #0f172a; text-align: center; }
        #hint-text { color: #475569; font-size: 1rem; margin-bottom: 20px; }

        #drop-zone {
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 20px 0;
            min-height: 110px;
            background: rgba(255,255,255,0.4);
            border-radius: 24px;
            padding: 15px;
            transition: all 0.4s ease;
        }

        #drop-zone.merged {
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 10px 25px -5px rgba(14, 165, 233, 0.3);
            animation: happyWiggle 0.6s ease infinite alternate;
        }

        #piece-pool {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 20px;
            flex-wrap: wrap;
            width: 95%;
        }

        .slot {
            width: 60px;
            height: 60px;
            border: 3px dashed #cbd5e1;
            margin: 4px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            transition: all 0.3s ease;
        }

        #drop-zone.merged .slot {
            border-color: transparent !important;
            background: transparent !important;
            margin: 0 !important;
            border-radius: 0;
        }

        .piece {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3.2rem;
            cursor: grab;
            transition: transform 0.2s ease;
        }

        #reward-screen {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: #e0f2fe;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        #reward-screen h1 { font-size: 2.2rem; color: #0369a1; }

        @keyframes happyWiggle {
            0% { transform: scale(1) rotate(-3deg); }
            100% { transform: scale(1.05) rotate(3deg); }
        }

        button {
            padding: 15px 35px; font-size: 1.3rem; font-weight: bold; border-radius: 20px;
            border: none; background: #0ea5e9; color: white; box-shadow: 0 5px 0 #0369a1;
            cursor: pointer; margin-top: 20px;
        }
        button:active { transform: translateY(4px); box-shadow: none; }
    </style>
</head>
<body>

<div id="game-bar">Puzzle: <span id="lvl-num">1</span>/5</div>
<h1 id="animal-name">Loading...</h1>
<div id="hint-text">Put the pieces together in a line!</div>

<div id="drop-zone"></div>
<div id="piece-pool"></div>

<div id="reward-screen">
    <div style="font-size: 8rem; animation: happyWiggle 0.5s infinite alternate;">🏆</div>
    <h1>MASTER PUZZLE BUILDER!</h1>
    <p style="font-size: 1.2rem; color: #0369a1;">You solved every single surprise challenge!</p>
    <button onclick="location.reload()">Play Again! 🔄</button>
</div>

<script>
    const dropZone = document.getElementById('drop-zone');
    const piecePool = document.getElementById('piece-pool');
    const lvlNum = document.getElementById('lvl-num');
    const animalName = document.getElementById('animal-name');

    let currentRound = 1;
    let selectedLevels = [];

    // The Master Library of 10 Visual Patterns
    const puzzleLibrary = [
        { char: "🐟", parts: 3, name: "The Shiny Fish! 🐟", color: "#e0f2fe" },
        { char: "🐳", parts: 3, name: "The Blue Whale! 🐳", color: "#e0f2fe" },
        { char: "🚀", parts: 3, name: "The Space Rocket! 🚀", color: "#fef3c7" },
        { char: "🐛", parts: 4, name: "The Hungry Caterpillar! 🐛", color: "#dcfce7" },
        { char: "🚂", parts: 4, name: "The Choo-Choo Train! 🚂", color: "#fee2e2" },
        { char: "🦖", parts: 4, name: "The Green Dinosaur! 🦖", color: "#dcfce7" },
        { char: "🐊", parts: 5, name: "The Snappy Crocodile! 🐊", color: "#dcfce7" },
        { char: "🐉", parts: 5, name: "The Magic Dragon! 🐉", color: "#f3e8ff" },
        { char: "🚌", parts: 5, name: "The School Bus! 🚌", color: "#fef3c7" },
        { char: "🐍", parts: 6, name: "The Long, Long Snake! 🐍", color: "#ecfdf5" }
    ];

    function setupGameStructure() {
        // Shuffle the entire library
        let shuffledLibrary = [...puzzleLibrary].sort(() => Math.random() - 0.5);
        
        // Pick 5 puzzles for this playthrough session
        selectedLevels = shuffledLibrary.slice(0, 5);
        
        // Sort them by piece count so it still goes from easiest to hardest!
        selectedLevels.sort((a, b) => a.parts - b.parts);
    }

    function loadLevel(roundIndex) {
        dropZone.innerHTML = '';
        piecePool.innerHTML = '';
        dropZone.classList.remove('merged');
        
        const data = selectedLevels[roundIndex - 1];
        lvlNum.textContent = roundIndex;
        animalName.textContent = data.name;
        document.body.style.backgroundColor = data.color;

        // Create slots matching the piece sizes
        for(let i=0; i < data.parts; i++) {
            const slot = document.createElement('div');
            slot.classList.add('slot');
            dropZone.appendChild(slot);
        }

        let pieces = [];
        for(let i=0; i < data.parts; i++) {
            const p = document.createElement('div');
            p.classList.add('piece');
            p.textContent = data.char;
            p.dataset.correctOrder = i;
            
            let start = (i / data.parts) * 100;
            let end = ((i + 1) / data.parts) * 100;
            p.style.clipPath = `inset(0 ${100 - end}% 0 ${start}%)`;
            
            p.style.width = (60 * data.parts) + "px";
            p.style.transform = `translateX(${((data.parts - 1) / 2 - i) * 100 / data.parts}%)`;
            
            const wrapper = document.createElement('div');
            wrapper.style.width = "60px";
            wrapper.style.height = "60px";
            wrapper.style.overflow = "hidden";
            wrapper.style.display = "flex";
            wrapper.style.justifyContent = "center";
            wrapper.style.borderRadius = "10px";
            wrapper.style.background = "white";
            wrapper.style.boxShadow = "0 4px 0 #cbd5e1";
            wrapper.appendChild(p);
            
            wrapper.dataset.correctOrder = i;
            wrapper.onpointerdown = startDrag;
            pieces.push(wrapper);
        }

        // Shuffle the pieces before scattering them in the tray
        pieces.sort(() => Math.random() - 0.5).forEach(p => piecePool.appendChild(p));
    }

    let activePiece = null;
    let offset = { x: 0, y: 0 };

    function startDrag(e) {
        if(dropZone.classList.contains('merged')) return;
        
        activePiece = e.currentTarget;
        activePiece.setPointerCapture(e.pointerId);
        const rect = activePiece.getBoundingClientRect();
        offset.x = e.clientX - rect.left;
        offset.y = e.clientY - rect.top;
        
        activePiece.style.position = 'fixed';
        activePiece.style.zIndex = '100';

        activePiece.onpointermove = (ev) => {
            activePiece.style.left = (ev.clientX - offset.x) + 'px';
            activePiece.style.top = (ev.clientY - offset.y) + 'px';
        };

        activePiece.onpointerup = (ev) => {
            activePiece.onpointermove = null;
            activePiece.onpointerup = null;
            activePiece.style.display = 'none';
            let target = document.elementFromPoint(ev.clientX, ev.clientY);
            let slot = target ? target.closest('.slot') : null;
            activePiece.style.display = 'flex';
            activePiece.style.position = 'static';

            if (slot && !slot.hasChildNodes()) {
                slot.appendChild(activePiece);
                activePiece.style.borderRadius = "0px";
                activePiece.style.boxShadow = "none";
            } else {
                activePiece.style.borderRadius = "10px";
                activePiece.style.boxShadow = "0 4px 0 #cbd5e1";
                piecePool.appendChild(activePiece);
            }
            checkWin();
        };
    }

    function checkWin() {
        const slots = document.querySelectorAll('.slot');
        let currentSequence = "";
        let filledCount = 0;
        const currentData = selectedLevels[currentRound - 1];

        slots.forEach(s => {
            if(s.firstChild) {
                currentSequence += s.firstChild.dataset.correctOrder;
                filledCount++;
            }
        });

        let targetSequence = Array.from({length: currentData.parts}, (_, i) => i).join('');
        
        if (filledCount === currentData.parts) {
            if (currentSequence === targetSequence) {
                dropZone.classList.add('merged');
                slots.forEach(s => { if (s.firstChild) s.firstChild.style.background = "transparent"; });

                setTimeout(() => {
                    if(currentRound < 5) {
                        currentRound++;
                        loadLevel(currentRound);
                    } else {
                        document.getElementById('reward-screen').style.display = 'flex';
                    }
                }, 1800);
            } else {
                setTimeout(() => {
                    slots.forEach(s => { 
                        if(s.firstChild) {
                            s.firstChild.style.borderRadius = "10px";
                            s.firstChild.style.boxShadow = "0 4px 0 #cbd5e1";
                            piecePool.appendChild(s.firstChild); 
                        }
                    });
                }, 600);
            }
        }
    }

    // Run Engine Configuration
    setupGameStructure();
    loadLevel(1);
</script>
 

<br>
<br>
<br>

<center>
<table>
<tr>
	<td>
	 <center><a href='/seqn3'><img src="np.png" width="150" length="200"></a></center>
	</td>

	<td>
	 <center><a href='/1'><img src="ACT.png" width="150" length="150"></a></center>
	</td>
</tr>
</table>
</center>


</body>
</html>