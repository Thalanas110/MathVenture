<!DOCTYPE html>
<html lang="en">
 
<body background="3bg.jpg">

<table>
	<tr>
		<td>
		<a href='/3'><img src="1seq.png" width="250" length="600"></a>

		</td>
	
	</tr>
	</table>


<head>
  <title>Sequence Game for Kids</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      background-color: #f0f8ff;
    }

    h1 {
      color: #ff69b4;
    }

    .game-container {
      margin-top: 30px;
    }

    .number {
      display: inline-block;
      width: 80px;
      height: 80px;
      line-height: 80px;
      margin: 10px;
      font-size: 30px;
      background-color: #87cefa;
      border-radius: 10px;
      cursor: pointer;
    }

    .number:hover {
      background-color: #00bfff;
    }

    #message {
      margin-top: 20px;
      font-size: 20px;
      font-weight: bold;
    }

    button {
      margin-top: 20px;
      padding: 10px 20px;
      font-size: 16px;
    }
  </style>
</head>
<body>

  <h1> Ayusin ang mga numero sa pinaka mababa papuntang pinaka mataas!</h1>

  <div class="game-container" id="game"></div>

  <div id="message"></div>
  <button onclick="startGame()">Restart Game</button>

  <script>
    let sequence = [1, 2, 3, 4, 5];
    let current = 0;

    function shuffle(array) {
      for (let i = array.length - 1; i > 0; i--) {
        let j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[j], array[i]];
      }
    }

    function startGame() {
      current = 0;
      document.getElementById("message").textContent = "";
      let gameDiv = document.getElementById("game");
      gameDiv.innerHTML = "";

      let shuffled = [...sequence];
      shuffle(shuffled);

      shuffled.forEach(num => {
        let div = document.createElement("div");
        div.className = "number";
        div.textContent = num;

        div.onclick = function() {
          if (num === sequence[current]) {
            div.style.backgroundColor = "#90ee90";
            current++;

            if (current === sequence.length) {
              document.getElementById("message").textContent = "🎉 Great job! You got it!";
            }
          } else {
            document.getElementById("message").textContent = "❌ Try again!";
          }
        };

        gameDiv.appendChild(div);
      });
    }

    startGame();
  </script>
<br>
